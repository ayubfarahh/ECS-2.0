{
    "containerDefinitions": [
        {
            "name": "ecsv2-container",
            "image": "940622738555.dkr.ecr.eu-west-2.amazonaws.com/green:v2",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "TABLE_NAME",
                    "value": "dynamodb-table"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/url-shortener",
                    "awslogs-region": "eu-west-2",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "family": "ecsv2-task",
    "taskRoleArn": "arn:aws:iam::940622738555:role/task-role",
    "executionRoleArn": "arn:aws:iam::940622738555:role/ecs-task-execution-role",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512"
}